# Faun — AI Forest Monitoring System
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# === Required secrets ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_DRONE_BOT_TOKEN=
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# === AI Studio (RAG / DataSphere) ===
SEARCH_INDEX_ID=
DATASPHERE_NODE_ID=

# === YDB Serverless (enables persistent cloud storage) ===
# When set, the system switches from SQLite to YDB automatically.
# YDB_ENDPOINT=grpcs://ydb.serverless.yandexcloud.net:2135
# YDB_DATABASE=/ru-central1/b1g.../etn...
# YDB_SA_KEY_FILE=/app/sa-key.json

# === Optional (defaults shown) ===
# ALERT_COOLDOWN_SECONDS=300
# CLOUD_API_URL=http://cloud:8000
# LORA_GATEWAY_HOST=lora_gateway
# LORA_GATEWAY_PORT=9000
# MIC_MODE=sim
# DEMO_SCENARIO=chainsaw

# === Microphone coordinates (defaults: Moscow test area) ===
# MIC_A_LAT=55.7510
# MIC_A_LON=37.6130
# MIC_B_LAT=55.7515
# MIC_B_LON=37.6138
# MIC_C_LAT=55.7508
# MIC_C_LON=37.6142
