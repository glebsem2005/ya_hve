# Yandex Cloud Foundation Models
# Get API key: https://yandex.cloud/docs/iam/operations/api-key/create
YANDEX_API_KEY=your_api_key_here
YANDEX_FOLDER_ID=your_folder_id_here

# Telegram Bot
# Create bot: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Microphone positions (lat/lon for 3 mics)
MIC_A_LAT=55.7510
MIC_A_LON=37.6130
MIC_B_LAT=55.7515
MIC_B_LON=37.6138
MIC_C_LAT=55.7508
MIC_C_LON=37.6142

# LoRa Gateway
LORA_GATEWAY_HOST=lora_gateway
LORA_GATEWAY_PORT=9000

# Microphone mode: sim | real | real_3
MIC_MODE=sim
MIC_DEVICE_ID=0
MIC_DEVICE_IDS=0,1,2

# Demo scenario: chainsaw | gunshot | normal
DEMO_SCENARIO=chainsaw
